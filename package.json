{
  "name": "snapdesk",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @snapdesk/db generate",
    "db:migrate": "pnpm --filter @snapdesk/db migrate",
    "db:studio": "pnpm --filter @snapdesk/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "@types/node": "^20.16.10",
    "prettier": "^3.3.3",
    "eslint": "^9.39.1",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.61.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-import-resolver-typescript": "^3.6.3"
  }
}
