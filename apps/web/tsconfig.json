{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@snapdesk/core": ["../../packages/core/src/index.ts"],
      "@snapdesk/core/*": ["../../packages/core/src/*"],
      "@snapdesk/types": ["../../packages/types/src/index.ts"],
      "@snapdesk/types/*": ["../../packages/types/src/*"],
      "@snapdesk/db": ["../../packages/db/src/index.ts"],
      "@snapdesk/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
