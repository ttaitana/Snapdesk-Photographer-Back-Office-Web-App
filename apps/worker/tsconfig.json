{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@snapdesk/core": ["../../packages/core/src/index.ts"],
      "@snapdesk/core/*": ["../../packages/core/src/*"],
      "@snapdesk/db": ["../../packages/db/src/index.ts"],
      "@snapdesk/db/*": ["../../packages/db/src/*"],
      "@snapdesk/queue": ["../../packages/queue/src/index.ts"],
      "@snapdesk/queue/*": ["../../packages/queue/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
