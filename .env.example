# Copy this file to `.env` (gitignored) and fill in real values.
# Validated on startup by apps/web/lib/env.ts — see SPEC.md §6.

# ── App ──
NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://user:pass@localhost:5432/snapdesk
REDIS_URL=redis://localhost:6379    # BullMQ queue (apps/worker, from P8)

# ── Better Auth ──
# SPEC.md says "Auth.js (NextAuth)" — switched to Better Auth (the Auth.js
# team's own successor project as of late 2025) before writing any P1 code;
# see the note at the top of packages/db/prisma/schema.prisma.
AUTH_SECRET=                  # openssl rand -base64 32

# ── Resend (real email delivery for team invites — P1) ──
RESEND_API_KEY=                # https://resend.com/api-keys
EMAIL_FROM="Snapdesk <onboarding@resend.dev>"   # swap for a verified domain sender once you have one

# ── Google (OAuth + Calendar + Drive) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# scopes: openid email profile
#         https://www.googleapis.com/auth/calendar.events
#         https://www.googleapis.com/auth/drive.readonly

# ── Microsoft (OAuth + Outlook Calendar + OneDrive) ──
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
# scopes: openid email profile offline_access
#         Calendars.ReadWrite  Files.Read.All

# ── (optional) Storage for QR image / receipt uploads ──
STORAGE_BUCKET=
STORAGE_KEY=
STORAGE_SECRET=
