// @snapdesk/db — Prisma schema (source of truth for the data model).
//
// Models are added progressively per TASKS.md:
//   P1 — Better Auth core tables (User, Session, Account, Verification) +
//        organization-plugin tables renamed to Team, TeamMember, TeamInvite  [done]
//   P2 — Customer, Job (+ JobStatus), Payment (+ PaymentType)                [done]
//   P4 — Package, JobAssignment (+ ShareType)                                [done]
//   P6 — Expense (+ Team.revenueBasis)                                       [done]
//        TaxSetting, MemberTaxProfile (ภาษี sub-phase)                 [in progress]
//   P7 — DeliveryQr
//
// Full target shape lives in SPEC.md §4 — copy models over verbatim when
// their phase starts so we don't drift from the spec.
//
// Every business-data model carries `teamId` and must be queried through
// `@snapdesk/core` services that scope by team — see SPEC.md §3 (security).
//
// ── Why Better Auth instead of Auth.js (SPEC.md literally says "Auth.js
// (NextAuth)") ──
// In Sept 2025 the Auth.js team joined Better Auth; Auth.js is now
// maintenance-only (security patches, no new features) and still tagged
// beta. Better Auth is their own recommended choice for new projects as of
// mid-2026, and its `organization` plugin maps directly onto this project's
// Team/TeamMember/role model. Decided with the user via AskUserQuestion
// before writing any P1 code.
//
// ── Hand-written, not CLI-generated ──
// Normally `npx @better-auth/cli generate` writes this schema for you. That
// command needs network access to resolve the Better Auth config module,
// which isn't available in the sandbox that authored this file, so the
// User/Session/Account/Verification models below were transcribed by hand
// from Better Auth's documented schema (https://better-auth.com/docs/concepts/database)
// and the organization plugin's schema
// (https://better-auth.com/docs/plugins/organization). Double-check against
// those pages if Better Auth's schema ever changes.
//
// ── Naming decisions worth knowing about ──
// 1. Organization-plugin model names are renamed via `schema.<model>.modelName`
//    in packages/auth (Team / TeamMember / TeamInvite) so the rest of the
//    codebase — which says "team" everywhere per TASKS.md/SPEC.md — reads
//    naturally. The plugin's *field* names inside those tables (organizationId,
//    role, status, inviterId, logo, slug...) are left as Better Auth's
//    defaults: Better Auth's `fields` remap only changes the physical column,
//    not the JS-level property the library reads/writes, so renaming them
//    would buy nothing and risks drifting from undocumented internals we
//    can't verify without running the CLI. `packages/auth`'s team service is
//    the only place that talks to these tables directly — it translates
//    `organizationId` → `teamId`, `logo` → `logoUrl`, etc. before handing
//    data to the rest of the app, so nothing above that layer ever sees
//    Better Auth's vocabulary. See packages/auth/src/team-mapping.ts.
// 2. Role strings are lowercase ("owner" | "admin" | "member") to match
//    Better Auth's built-in access-control defaults, NOT the uppercase
//    OWNER/ADMIN/MEMBER originally sketched in packages/types — fighting the
//    plugin's default casing via custom access-control roles was judged
//    riskier than a one-time lowercase rename of a not-yet-used zod enum.
//    `packages/types` enums.ts was updated to match; UI capitalizes for
//    display ("Owner"/"Admin"/"Member").
// 3. `Session.activeOrganizationId` keeps Better Auth's literal field name
//    even though it conceptually means "this session's active **team**" —
//    SPEC.md's `User.activeTeamId` placement isn't how the organization
//    plugin tracks the active org (it lives on the session, not the user,
//    so it can differ per device/tab). The team-switcher and team-context
//    resolver read/write it through Better Auth's `setActiveOrganization` /
//    `getSession` APIs, never directly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Better Auth core tables ──

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// App-level preference, not part of Better Auth's default user schema —
  /// added via `user.additionalFields.theme` in packages/auth. Mirrors
  /// `ThemeMode` in @snapdesk/types.
  theme String @default("system")

  sessions      Session[]
  accounts      Account[]
  memberships   TeamMember[]
  sentInvites   TeamInvite[]  @relation("TeamInviteInviter")

  /// P2 — jobs this user created (audit trail). See Job.createdById below.
  createdJobs   Job[]         @relation("JobCreatedBy")

  /// P4 — revenue-split assignments across jobs this user worked on.
  jobAssignments JobAssignment[]

  /// P6 — expenses this user recorded (audit trail, same convention as
  /// Job.createdById). See Expense.createdById below.
  recordedExpenses Expense[] @relation("ExpenseCreatedBy")

  /// P6 — this user's own PIT settings (per team). See MemberTaxProfile below.
  taxProfiles MemberTaxProfile[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The team this session is currently "switched to" — written by Better
  /// Auth's organization plugin (`setActiveOrganization`), read by the
  /// team-context resolver in @snapdesk/core. See naming note #3 above.
  activeOrganizationId String?

  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken            String?
  refreshToken           String?
  idToken                String?
  accessTokenExpiresAt   DateTime?
  refreshTokenExpiresAt  DateTime?
  scope                  String?

  /// Only set for the credentials (email+password) provider — Better Auth
  /// hashes it (scrypt by default) before it ever reaches this column, so
  /// this is never plaintext. Satisfies SPEC.md §5's "never store plaintext
  /// password" requirement even though the spec named bcrypt/argon2
  /// specifically; scrypt is an equally-acceptable OWASP-recommended KDF and
  /// is what Better Auth ships by default.
  password String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ── organization plugin tables, renamed to match this project's "Team"
// vocabulary (see naming note #1 above) ──

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  /// Added via `organization.additionalFields` — not part of Better Auth's
  /// default organization schema. Matches SPEC.md §4's Team model.
  businessName String?
  taxId        String?

  members     TeamMember[]
  invitations TeamInvite[]

  /// P2 — business data, always scoped by teamId. See SPEC.md §3 (security):
  /// every query against these must go through @snapdesk/core services that
  /// filter by the caller's resolved team-context, never trust a client-
  /// supplied teamId directly.
  customers Customer[]
  jobs      Job[]

  /// P4 — quotation packages this team has defined. See SPEC.md §4.
  packages  Package[]

  /// P6 — รายรับ-รายจ่าย (F7). See Expense below.
  expenses  Expense[]

  /// P6 — revenue recognition basis for the income/expense summary
  /// ("cash" = count income when Payment.paidAt happens, the default;
  /// "accrual" = count income when the Job is confirmed/delivered instead).
  /// Lives directly on Team rather than introducing TaxSetting early —
  /// TaxSetting/MemberTaxProfile are deferred to P6's tax sub-phase per the
  /// user's "Expense + Summary first" priority call, and this setting isn't
  /// tax-specific so it doesn't need to wait for that model to exist.
  revenueBasis String @default("cash")

  /// P6 — ภาษี: team-level VAT settings (on/off, rate, editable PIT bracket
  /// table). One-to-one — a team either has its TaxSetting row or hasn't
  /// configured tax yet (service layer treats a missing row as "VAT off,
  /// default brackets"). See TaxSetting below.
  taxSetting TaxSetting?

  /// P6 — ภาษี: per-member PIT profile (income type, deduction method,
  /// allowances, default WHT rate). See MemberTaxProfile below.
  memberTaxProfiles MemberTaxProfile[]

  @@map("team")
}

model TeamMember {
  id             String   @id @default(cuid())
  organizationId String
  team           Team     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Lowercase to match Better Auth's built-in access-control defaults —
  /// see naming note #2 above. One of: "owner" | "admin" | "member".
  role String @default("member")

  createdAt DateTime @default(now())

  @@unique([organizationId, userId])
  @@map("team_member")
}

model TeamInvite {
  id             String    @id @default(cuid())
  organizationId String
  team           Team      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String    @default("member")

  /// One of: "pending" | "accepted" | "rejected" | "canceled" (Better Auth
  /// defaults).
  status String @default("pending")

  expiresAt DateTime
  inviterId String
  inviter   User     @relation("TeamInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("team_invite")
}

// ── P2 — Core Data Layer ──
//
// Customer / Job / Payment, mirrored from SPEC.md §4. Money fields use
// Decimal (not Float) to avoid floating-point drift on currency; the
// @snapdesk/core service layer converts Decimal <-> plain `number` at the
// boundary so the rest of the app can keep using the `number`-based zod
// schemas in @snapdesk/types (customer.ts/job.ts/payment.ts) unchanged.
//
// `Job.packageId` originally had NO Prisma relation (Package didn't exist
// until P4) — the relation was added below once Package landed.

model Customer {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  email     String?
  lineId    String?
  /// IG handle/username — added for task #12 (TASKS.md F5: "form เพิ่ม/แก้
  /// ลูกค้า ... IG ..."), distinct from `channel` (which channel is the
  /// customer's *primary* one). Needs `pnpm prisma migrate dev` (or
  /// equivalent) run locally — no migration runner in this sandbox.
  instagram String?
  channel   String?
  note      String?

  jobs      Job[]

  createdAt DateTime @default(now())

  @@index([teamId])
  @@map("customer")
}

enum JobStatus {
  INQUIRY
  QUOTED
  CONFIRMED
  SHOOTING
  EDITING
  DELIVERED
  COMPLETED
  CANCELLED
}

model Job {
  id           String    @id @default(cuid())
  teamId       String
  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  /// Audit: who created this job. See User.createdJobs above.
  createdById  String
  createdBy    User      @relation("JobCreatedBy", fields: [createdById], references: [id])

  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])

  title        String
  shootType    String?
  status       JobStatus @default(INQUIRY)

  shootDate    DateTime?
  shootTime    String?

  locationName String?
  locationLat  Float?
  locationLng  Float?
  locationUrl  String?

  description  String?
  /// [{ id, item, done }] — see ChecklistItem in @snapdesk/types/job.ts.
  /// P3 (คิวถ่าย UI) is where this actually gets edited; P2 just needs the
  /// column and the service-layer read/write.
  checklist    Json?

  totalPrice   Decimal   @default(0)

  /// P4 — ใบเสนอราคา (Feature 2) fields. Not sketched on Job in SPEC.md §4's
  /// schema snippet (which has no separate Quotation model either), but the
  /// feature text explicitly needs them, so they live here next to
  /// totalPrice/packageId rather than inventing an unsketched model.
  /// `discount` and `quotedDeposit` are absolute Baht amounts (not %) to
  /// match how `totalPrice` itself is stored.
  discount       Decimal?  @default(0)
  quotedDeposit  Decimal?
  quoteExpiresAt DateTime?

  packageId    String?
  package      Package?  @relation(fields: [packageId], references: [id])

  deliveryLink String?

  payments     Payment[]

  /// P4 — revenue-split assignments (F3). See JobAssignment below.
  assignments  JobAssignment[]

  /// P6 — expenses linked to this specific job (e.g. travel cost for this
  /// shoot). Optional — Expense.jobId is nullable for general team expenses.
  expenses     Expense[]

  createdAt    DateTime  @default(now())

  @@index([teamId])
  @@index([customerId])
  @@index([packageId])
  @@map("job")
}

enum PaymentType {
  DEPOSIT
  BALANCE
  FULL
}

model Payment {
  id          String      @id @default(cuid())
  jobId       String
  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  amount      Decimal
  /// Withholding-tax rate (%) and the resulting amount withheld. Computed by
  /// the payments service from paymentInputSchema's `whtRate` — these are
  /// NOT accepted directly from client input. See SPEC.md §5 Feature 7.
  whtRate     Decimal     @default(0)
  whtAmount   Decimal     @default(0)
  /// amount - whtAmount, also computed server-side.
  netReceived Decimal?

  type        PaymentType
  paidAt      DateTime    @default(now())
  method      String?
  note        String?

  @@index([jobId])
  @@map("payment")
}

// ── P4 — ใบเสนอราคา (F2) + Tracking & แบ่งรายได้ (F3) ──
//
// Package: reusable quotation packages a team can pick from when building a
// Job's quotation (or the form can be filled manually, leaving packageId
// null — see jobInputSchema). `price` is Decimal for the same reason as
// Job.totalPrice. `items` is a free-form JSON list (e.g. ["2 ช่างภาพ", "อัลบั้ม
// 30 หน้า"]) shown on the PDF/quotation, mirrors Job.checklist's pattern.

model Package {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name        String
  price       Decimal
  description String?
  /// Free-form list of package inclusions, e.g. ["ช่างภาพ 1 คน", "รูปแต่ง 30 ภาพ"].
  items       Json?

  jobs        Job[]

  createdAt   DateTime @default(now())

  @@index([teamId])
  @@map("package")
}

enum ShareType {
  PERCENT
  FIXED
}

// JobAssignment: who worked a job and how the job's payout is split between
// them. No `teamId` column of its own — scoped via the parent Job, same
// `requireJobInTeam` pattern as Payment (packages/core/src/payments).
//
// Split math (SPEC.md §4, verbatim rule): FIXED shares are deducted from the
// job total first; PERCENT shares are then computed against what's left
// after all FIXED shares are removed. Whatever isn't claimed by any
// assignment is the team/studio's own pool. The sum of all assignments'
// resolved Baht amounts must never exceed the job's totalPrice — validated
// in @snapdesk/core, not here.
model JobAssignment {
  id         String    @id @default(cuid())
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Free-text role label for this job specifically (e.g. "ช่างภาพหลัก",
  /// "ผู้ช่วย", "ตัดต่อ") — distinct from TeamMember.role (team-level
  /// owner/admin/member permissions).
  roleOnJob  String?

  shareType  ShareType
  /// Meaning depends on shareType: a percentage (0–100) when PERCENT, or an
  /// absolute Baht amount when FIXED.
  shareValue Decimal

  createdAt  DateTime  @default(now())

  @@unique([jobId, userId])
  @@map("job_assignment")
}

// ── P6 — รายรับ-รายจ่าย + ภาษีไทย (F7), Expense + Summary sub-phase ──
//
// Expense, mirrored from SPEC.md §4. Has its own `teamId` (unlike Payment),
// so it follows the simpler customers/packages CRUD pattern, not the
// requireJobInTeam-via-parent pattern. `jobId` is optional — an expense can
// be tied to a specific shoot (e.g. travel cost) or be a general team
// expense (e.g. equipment) with jobId left null.
//
// `category` is free text (เดินทาง/อุปกรณ์/ผู้ช่วย/อื่นๆ are suggestions, not an
// enum) — same precedent as Customer.channel/Job.shootType, since SPEC.md's
// sketch doesn't define a fixed category enum and the UI just needs
// something to group/filter by.
//
// `receiptUrl` is a plain URL string, not a real file upload — the project
// has no upload/storage infra yet anywhere (Team.logoUrl follows the same
// pattern), so this matches existing precedent until one exists.

model Expense {
  id          String    @id @default(cuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  /// Audit: who recorded this expense. See User.recordedExpenses above.
  createdById String
  createdBy   User      @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  jobId       String?
  job         Job?      @relation(fields: [jobId], references: [id])

  category    String
  amount      Decimal
  spentAt     DateTime  @default(now())
  note        String?
  receiptUrl  String?

  createdAt   DateTime  @default(now())

  @@index([teamId])
  @@index([jobId])
  @@map("expense")
}

// ── P6 tax sub-phase — ภาษี (F7) ──
//
// Plain app models (teamId/userId field names, like Expense/Customer/Job
// above) — NOT Better Auth tables, so naming note #1's organizationId
// rename doesn't apply here. All money/percent fields use Decimal +
// decimalToNumber() per packages/core/src/lib/decimal.ts convention.
//
// Pure calculation (VAT split, WHT credit split, PIT bracket math) lives in
// packages/tax-th and never touches these models directly; packages/core's
// tax service reads/writes them and feeds resolved numbers into tax-th.
//
// IMPORTANT: every tax figure these models feed into the UI is an ESTIMATE
// for planning only — see the in-app disclaimer required by TASKS.md/SPEC.md
// (rendered in apps/web/app/team/tax/page.tsx).

model TaxSetting {
  id     String @id @default(cuid())
  teamId String @unique
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  vatRegistered Boolean @default(false)
  vatRate       Decimal @default(7)

  /// Editable PIT bracket table shared by every member of this team unless
  /// packages/tax-th's built-in default is used instead (null) —
  /// [{ min: number, max: number | null, rate: number }], rate as a whole
  /// percent (e.g. 5, not 0.05). "TASKS.md: แก้ bracket ได้".
  pitBrackets Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_setting")
}

model MemberTaxProfile {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// เงินได้ประเภท 40(2) (รับจ้างทำงาน/ค่านายหน้า) หรือ 40(8) (เงินได้อื่นๆ เช่น
  /// ช่างภาพอิสระขายงาน) — "แต่ละคนเลือกประเภทเงินได้เองได้" (SPEC.md F7).
  incomeType String @default("40_2")

  /// หักค่าใช้จ่ายแบบเหมา (flat %, capped) หรือตามจริง (actual, documented).
  expenseMethod String @default("flat")

  /// ค่าลดหย่อนที่เลือกใช้ — [{ label: string, amount: number }]. Free-form
  /// JSON since the allowance list/amounts change by year's RD announcement
  /// (see disclaimer) rather than a fixed enum.
  deductions Json?

  /// Suggested WHT rate (%) when recording this member's payments — 3, 2,
  /// or 0. Payment.whtRate stays independently settable per payment
  /// (packages/core/src/payments); this is only a default.
  defaultWhtRate Decimal @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@map("member_tax_profile")
}
